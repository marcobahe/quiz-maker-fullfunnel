datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String              @id @default(cuid())
  name                 String?
  email                String              @unique
  password             String?
  image                String?
  role                 String              @default("user") // "owner" | "admin" | "user"
  plan                 String              @default("free")
  suspended            Boolean             @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  onboardingDone       Boolean             @default(false)
  quizzes              Quiz[]
  customDomains        CustomDomain[]
  ownedWorkspaces      Workspace[]         @relation("WorkspaceOwner")
  memberships          WorkspaceMember[]
  mediaAssets          MediaAsset[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model Quiz {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  workspaceId  String?
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id])
  name         String
  slug         String           @unique
  description  String?
  status       String           @default("draft")
  canvasData   String?
  settings     String           @default("{}")
  scoreRanges  String           @default("[]")
  emailNotifications  Boolean  @default(false)
  notificationMode    String?  // 'instant-hot', 'daily', 'weekly'  
  notificationEmail   String?  // email para receber (default: email do user)
  shuffleQuestions    Boolean  @default(false)
  questionTimer       Int?     // segundos por pergunta (null = sem timer)
  leads        Lead[]
  integrations Integration[]
  analytics    AnalyticsEvent[]
  // A/B Testing
  parentId     String?
  parent       Quiz?            @relation("QuizVariants", fields: [parentId], references: [id])
  variants     Quiz[]           @relation("QuizVariants")
  splitPercent  Int?             @default(50)
  isVariant     Boolean          @default(false)
  customDomains CustomDomain[]
  // Outbound webhook (generic — any platform)
  webhookUrl    String?
  webhookSecret String?
  webhookLogs   WebhookLog[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Workspace {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  ownerId        String
  owner          User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members        WorkspaceMember[]
  quizzes        Quiz[]
  // GHL self-service integration
  ghlApiKey      String?           // encrypted at rest via AES-256-GCM (fieldEncryption.js)
  ghlSyncStatus  String            @default("not_configured") // "not_configured" | "active" | "pending_setup" | "error"
  ghlAccountName String?           // plain text — display name from GHL location
  ghlLocationId  String?           // plain text — GHL sub-account location ID
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("editor") // "owner" | "admin" | "editor" | "viewer"
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model Lead {
  id             String   @id @default(cuid())
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id])
  name           String?
  email          String?
  phone          String?
  answers        String?
  score          Int      @default(0)
  resultCategory String?
  metadata       String   @default("{}")
  country        String?
  region         String?
  city           String?
  attribution    Json?
  createdAt      DateTime @default(now())
}

model Integration {
  id        String   @id @default(cuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  type      String   // "webhook" | "gohighlevel"
  name      String   @default("")
  config    String   // JSON string with configuration
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  quizId     String
  quiz       Quiz     @relation(fields: [quizId], references: [id])
  sessionId  String?
  event      String
  nodeId     String?
  questionId String?
  data       String   @default("{}")
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model CustomDomain {
  id          String   @id @default(cuid())
  domain      String   @unique
  quizId      String?
  quiz        Quiz?    @relation(fields: [quizId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  verified    Boolean  @default(false)
  active      Boolean  @default(true)
  cnameTarget String   @default("play.quizmebaby.app")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WebhookLog {
  id             String   @id @default(cuid())
  // Soft reference — no FK so records survive quiz deletion
  quizId         String?
  quiz           Quiz?    @relation(fields: [quizId], references: [id])
  leadId         String?
  attempt        Int      @default(1)
  // 'success' | 'failed' | 'dlq'
  status         String   @default("failed")
  statusCode     Int?
  responseTimeMs Int?
  lastError      String?
  createdAt      DateTime @default(now())

  @@index([quizId])
  @@index([status])
  @@index([createdAt])
}

model WhatsappMessageLog {
  id            String    @id @default(cuid())
  // Soft references — no FK constraints so records survive lead/quiz deletion
  leadId        String?
  quizId        String?
  integrationId String?
  phone         String
  message       String
  // 'pending' | 'success' | 'failed' | 'dlq'
  status        String    @default("pending")
  error         String?
  attemptCount  Int       @default(0)
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([leadId])
  @@index([quizId])
}

model MediaAsset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId    String?  // soft ref — survives quiz deletion for audit
  fileKey   String   @unique
  fileName  String
  fileType  String   // 'image' | 'audio' | 'video'
  fileSize  Int
  url       String
  endpoint  String   // 'imageUploader' | 'audioUploader' | 'videoUploader'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([quizId])
  @@index([fileType])
  @@index([createdAt])
}
